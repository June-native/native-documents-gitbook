    "/v1/aqua/liquidation": {
      "post": {
        "operationId": "AquaController_requestLiquidation",
        "summary": "Whitelisted liquidator can request for Marker Maker liquidation by specifying what position they want to close and how much collateral they want to claim. Liquidator can do partial liquidation as long as the Market Maker credit health is increasing.",
        "parameters": [
          {
            "name": "apiKey",
            "in": "header",
            "description": "The API key that was assigned to you by Native",
            "schema": {
              "type": "string"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/LiquidationRequestDto"
              }
            }
          }
        },
