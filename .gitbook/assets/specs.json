  "info": {
    "title": "Lend API",
    "description": "Public endpoints for Lend API.",
    "version": "1.0",
    "contact": {

    }
  },
  "tags": [],
  "servers": [
    {
      "url": "https://newapi.native.org/swap-api"
    }
  ],
  "components": {
    "schemas": {
      "TokenAmount": {
        "type": "object",
        "properties": {
          "tokenAddress": {
            "type": "string",
            "description": "The address of the traded token",
            "pattern": "^0x[a-fA-F0-9]{40}$"
          },
          "amount": {
            "type": "string",
            "description": "Amount of token in wei unit",
            "pattern": "^0x[a-fA-F0-9]{40}$"
          }
        },
        "required": [
          "tokenAddress",
          "amount"
        ]
      },
      "LiquidationRequestDto": {
        "type": "object",
        "properties": {
          "trader": {
            "type": "string",
            "description": "The address of the trader",
            "pattern": "^0x[a-fA-F0-9]{40}$"
          },
          "recipient": {
            "type": "string",
            "description": "The address of the market maker or the settler",
            "pattern": "^0x[a-fA-F0-9]{40}$"
          },
          "chain": {
            "type": "string",
            "enum": [
              "ethereum",
              "bsc",
              "bsc_testnet",
              "sepolia",
              "polygon",
              "mumbai",
              "arbitrum",
              "avalanche",
              "mantle",
              "zetachain_athens3",
              "base",
              "manta",
              "scroll",
              "zetachain",
              "linea",
              "zklink",
              "morph_testnet",
              "morph_holesky_testnet",
              "mantle_sepolia_testnet"
            ],
            "description": "Native blockchain name, eg: ethereum, bsc, etc",
            "example": "ethereum"
          },
          "positionUpdates": {
            "description": "The market maker position(s) that you want to close",
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/TokenAmount"
            }
          },
          "claimCollaterals": {
            "description": "How much collateral you want to claim from the market maker",
            "type": "array",
