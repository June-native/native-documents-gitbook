{
  "openapi": "3.0.0",
  "paths": {
    "/v1/aqua/mm-positions": {
      "get": {
        "operationId": "AquaController_getAquaMMPosition",
        "summary": "Gets the market maker's current positions for the specific chain. \n    Note that there will be a time delay of 1 minute to 2 minute before Market Maker position is updated.",
        "parameters": [
          {
            "name": "address",
            "required": true,
            "in": "query",
            "description": "The address of the market maker",
            "schema": {
              "pattern": "^0x[a-fA-F0-9]{40}$",
              "type": "string"
            }
          },
          {
            "name": "chain",
            "required": true,
            "in": "query",
            "description": "Native blockchain name, eg: ethereum, bsc, etc",
            "example": "ethereum",
            "schema": {
              "enum": [
                "ethereum",
                "bsc",
                "bsc_testnet",
                "sepolia",
                "polygon",
                "mumbai",
                "arbitrum",
                "avalanche",
                "mantle",
                "zetachain_athens3",
                "base",
                "manta",
                "scroll",
                "zetachain",
                "linea",
                "zklink",
                "morph_testnet",
                "morph_holesky_testnet",
                "mantle_sepolia_testnet"
              ],
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Success"
          },
          "500": {
            "description": "There was an exception with the server"
          }
        },
        "tags": [
          "Aqua"
        ]
      }
    },
